             }
          }
 
          if (this.maxValue.isPresent()) {
             Optional<T> typedMaxValue = property.getValue((String)this.maxValue.get());
-            if (typedMaxValue.isEmpty() || value.compareTo((Comparable)typedMaxValue.get()) > 0) {
