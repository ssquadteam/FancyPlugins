Subject: [PATCH] Apply file patches


diff --git a/net/minecraft/core/component/DataComponentInitializers.java b/net/minecraft/core/component/DataComponentInitializers.java
index c4ae3ac0c0f32e8bbe69af13a8f5e46c86299664..d086409575eef89ed3066c7bb66e895debf7f7f0 100644
--- a/net/minecraft/core/component/DataComponentInitializers.java
+++ b/net/minecraft/core/component/DataComponentInitializers.java
