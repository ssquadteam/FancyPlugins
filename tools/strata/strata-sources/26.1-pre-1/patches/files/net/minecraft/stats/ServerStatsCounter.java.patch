@@ -57,7 +57,7 @@ public class ServerStatsCounter extends StatsCounter {
       Codec<T> valueCodec = type.getRegistry().byNameCodec();
       Codec<Stat<?>> statCodec = valueCodec.flatComapMap(
          type::get,
