Subject: [PATCH] Apply file patches


diff --git a/net/minecraft/stats/ServerStatsCounter.java b/net/minecraft/stats/ServerStatsCounter.java
index 57a0bdc60adb6fc37b5cae0c7a3968a16faf9781..598f7e48ffdb17ae66178befeae1a7080652e385 100644
