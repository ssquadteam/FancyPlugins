From 4ae198aa20a8bea0d0555a1787f4d957ef55d2fb Mon Sep 17 00:00:00 2001
From: Strata <strata@fancyinnovations.com>
Date: Thu, 12 Mar 2026 18:33:15 +0100
Subject: [PATCH] Apply file patches


diff --git a/net/minecraft/util/datafix/fixes/SignTextStrictJsonFix.java b/net/minecraft/util/datafix/fixes/SignTextStrictJsonFix.java
index f7fb3bc3f9dda4cf0e384bae3d8d64bec5e3e329..c252ce05b55ee39dcc6260ba354120682dee4b67 100644
--- a/net/minecraft/util/datafix/fixes/SignTextStrictJsonFix.java
+++ b/net/minecraft/util/datafix/fixes/SignTextStrictJsonFix.java
@@ -19,7 +19,7 @@ public class SignTextStrictJsonFix extends NamedEntityFix {
    protected Typed<?> fix(Typed<?> entity) {
       for (String lineField : LINE_FIELDS) {
          OpticFinder<?> lineF = entity.getType().findField(lineField);
-         OpticFinder<Pair<String, String>> textComponentF = DSL.typeFinder(this.getInputSchema().getType(References.TEXT_COMPONENT));
+         OpticFinder<Pair<String, String>> textComponentF = (OpticFinder<Pair<String, String>>) DSL.typeFinder(this.getInputSchema().getType(References.TEXT_COMPONENT));
          entity = entity.updateTyped(
             lineF, line -> line.update(textComponentF, textComponent -> textComponent.mapSecond(LegacyComponentDataFixUtils::rewriteFromLenient))
          );
