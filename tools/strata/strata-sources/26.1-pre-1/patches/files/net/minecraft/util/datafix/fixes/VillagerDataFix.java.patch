    protected Typed<?> fix(final Typed<?> entity) {
-      Dynamic<?> remainder = (Dynamic<?>)entity.get(DSL.remainderFinder());
+      Dynamic<?> remainder = entity.get(DSL.remainderFinder());
       return entity.set(
          DSL.remainderFinder(),
          remainder.remove("Profession")
@@ -29,7 +29,7 @@ public class VillagerDataFix extends NamedEntityFix {
                      remainder.createString("profession"),
