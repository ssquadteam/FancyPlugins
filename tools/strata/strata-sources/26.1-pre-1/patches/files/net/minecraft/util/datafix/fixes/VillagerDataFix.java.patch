Subject: [PATCH] Apply file patches


diff --git a/net/minecraft/util/datafix/fixes/VillagerDataFix.java b/net/minecraft/util/datafix/fixes/VillagerDataFix.java
index 7464ef97461384016a1f06bc42023aa58f2742a6..f6d8d569507d5e37ca236b46890506d1f6621208 100644
