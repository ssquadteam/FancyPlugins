From 4ae198aa20a8bea0d0555a1787f4d957ef55d2fb Mon Sep 17 00:00:00 2001
From: Strata <strata@fancyinnovations.com>
Date: Thu, 12 Mar 2026 18:33:15 +0100
Subject: [PATCH] Apply file patches


diff --git a/net/minecraft/util/profiling/jfr/stats/FileIOStat.java b/net/minecraft/util/profiling/jfr/stats/FileIOStat.java
index ab5906605cf6705aa797e490649688c1bf08c3c1..4f752a71e5283fdfee19cc815e503176a97630a8 100644
--- a/net/minecraft/util/profiling/jfr/stats/FileIOStat.java
+++ b/net/minecraft/util/profiling/jfr/stats/FileIOStat.java
@@ -16,11 +16,11 @@ public record FileIOStat(Duration duration, @Nullable String path, long bytes) {
          (double)totalBytes / recordingDuration.getSeconds(),
          ioStats.size(),
          (double)ioStats.size() / recordingDuration.getSeconds(),
-         (Duration)ioStats.stream().map(FileIOStat::duration).reduce(Duration.ZERO, Duration::plus),
-         ((Map)ioStats.stream().filter(it -> it.path != null).collect(Collectors.groupingBy(stat -> stat.path, Collectors.summingLong(it -> it.bytes))))
+         ioStats.stream().map(FileIOStat::duration).reduce(Duration.ZERO, Duration::plus),
+         (ioStats.stream().filter(it -> it.path != null).collect(Collectors.groupingBy(stat -> stat.path, Collectors.summingLong(it -> it.bytes))))
             .entrySet()
             .stream()
-            .sorted(Entry.comparingByValue().reversed())
+            .sorted(Entry.<String, Long>comparingByValue().reversed())
             .map(e -> Pair.of((String)e.getKey(), (Long)e.getValue()))
             .limit(10L)
             .toList()
